# ─── SERVER ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ─── DATABASE (MySQL) ─────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=saffron_catering

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_make_it_long
JWT_EXPIRES_IN=7d
JWT_ADMIN_SECRET=your_admin_jwt_secret_also_change_this

# ─── EMAIL (Nodemailer via Gmail) ─────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=Saffron Catering <your_gmail@gmail.com>

# ─── PAYPAL ───────────────────────────────────────────────────────────────────
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox

# ─── FILE UPLOAD ──────────────────────────────────────────────────────────────
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads
